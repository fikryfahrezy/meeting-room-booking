{
  "name": "front-end",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && if [ \"$NODE_ENV\" != 'production' -a \"$CI\" != 'true' ]; then msw init ./public --save; fi",
    "type-check": "vue-tsc --build --noEmit",
    "lint": "eslint --ext .ts,.vue .",
    "msw:init": "if [ \"$NODE_ENV\" != 'production' -a \"$CI\" != 'true' ]; then msw init ./public --save; fi",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.6.0",
    "@pinia/nuxt": "0.11.3",
    "@vueuse/core": "14.2.1",
    "@vueuse/nuxt": "14.2.1",
    "clsx": "2.1.1",
    "nuxt": "4.4.2",
    "pinia": "3.0.4",
    "tailwind-merge": "3.5.0",
    "vue": "3.5.31",
    "vue-router": "5.0.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "1.2.3",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/hints": "1.0.2",
    "@nuxt/test-utils": "4.0.0",
    "@playwright/test": "1.58.2",
    "@types/node": "24.12.0",
    "eslint": "9.39.2",
    "msw": "2.12.14",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vue-tsc": "3.2.6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
